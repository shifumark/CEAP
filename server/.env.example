# Copy this file to server/.env and fill in real values.
# dotenv.config() (server/src/index.ts) and the Prisma CLI both read
# server/.env — not the .env.example at the repo root.

NODE_ENV=development
PORT=4000

# JWT signing secret. REQUIRED — the server refuses to start without a
# real value at least 16 characters long (see server/src/lib/env.ts).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Never reuse the same secret across environments, and never commit the
# real value — this file only holds a placeholder.
JWT_SECRET=replace-with-output-of-the-command-above

# Frontend origin allowed by CORS (GitHub Pages URL in production).
CORS_ORIGIN=http://localhost:5173

# Supabase Postgres connection strings.
# DATABASE_URL: pooled connection (port 6543, via PgBouncer) — used at runtime.
# DIRECT_URL:   direct connection (port 5432) — used by `prisma migrate`.
# Both are on the Supabase project dashboard under Project Settings > Database.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase Storage (legacy — kept only as a fallback so documents uploaded
# before the Google Drive switch remain downloadable).
# Service role key is server-side only — never expose it to the client.
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Drive (current document storage). Service accounts can't write to
# a personal Google account's Drive (no storage quota of their own), so
# this uses standard OAuth 2.0 with a long-lived refresh token acting as
# the account that completed the one-time consent flow. drive.file scope
# only — the app can only see files it created itself, never the rest of
# the Drive. The OAuth consent screen must be "In production" (not
# "Testing"), or the refresh token expires after 7 days.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id
